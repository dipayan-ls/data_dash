# Data Integrity Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
#
# REQUIRED: Google Cloud / BigQuery credentials (choose one):
BIGQUERY_SERVICE_ACCOUNT_JSON=""   # Full JSON string of service account key
BIGQUERY_SERVICE_ACCOUNT_FILE=""   # OR path to JSON key file (default: ./credential_file.json)

# OPTIONAL: Override channel-specific credentials from Datastore defaults
META_ACCESS_TOKEN=""               # Meta (Facebook/Instagram) access token override
MICROSOFT_REFRESH_TOKEN=""         # Microsoft/Bing refresh token override
PINTEREST_BEARER_TOKEN=""          # Pinterest bearer token override
SNAPCHAT_REFRESH_TOKEN=""          # Snapchat refresh token override
TIKTOK_ACCESS_TOKEN=""             # TikTok access token override
REDDIT_CLIENT_ID=""                # Reddit app client ID
REDDIT_CLIENT_SECRET=""            # Reddit app client secret
REDDIT_REFRESH_TOKEN=""            # Reddit refresh token override
REDDIT_AD_ACCOUNT_ID=""            # Reddit ad account ID override
AMAZON_CLIENT_ID=""                # Amazon Ads client ID
AMAZON_CLIENT_SECRET=""            # Amazon Ads client secret
AMAZON_REFRESH_TOKEN=""            # Amazon Ads refresh token override

# OPTIONAL: Server config
PORT=3000                          # Flask backend port (default: 3000)
